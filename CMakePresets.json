{
    "version": 3,
    "configurePresets": [
        {
            "name": "vcpkg",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "vcpkg-emscripten",
            "hidden": true,
            "inherits": [
                "vcpkg"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/emsdk/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
                "VCPKG_TARGET_TRIPLET": "wasm32-emscripten"
            }
        },
        {
            "name": "vcpkg-emscripten-Debug",
            "inherits": [
                "vcpkg-emscripten"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "vcpkg-emscripten-RelWithDebInfo",
            "inherits": [
                "vcpkg-emscripten"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "vcpkg-emscripten-MinSizeRel",
            "inherits": [
                "vcpkg-emscripten"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel"
            }
        },
        {
            "name": "vcpkg-wasi",
            "hidden": true,
            "inherits": [
                "vcpkg"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/wasi-sdk/share/cmake/wasi-sdk.cmake",
                "VCPKG_TARGET_TRIPLET": "wasm32-emscripten",
                "WASI_SDK_PREFIX": "${sourceDir}/wasi-sdk",
                "CMAKE_SYSROOT": "${sourceDir}/wasi-sdk/share/wasi-sysroot"
            }
        },
        {
            "name": "vcpkg-wasi-Debug",
            "inherits": [
                "vcpkg-wasi"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "vcpkg-wasi-RelWithDebInfo",
            "inherits": [
                "vcpkg-wasi"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "vcpkg-wasi-MinSizeRel",
            "inherits": [
                "vcpkg-wasi"
            ],
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel"
            }
        }
    ]
}