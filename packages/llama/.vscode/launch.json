{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "serve-karma-test-browser",
            "type": "msedge",
            "request": "launch",
            "sourceMaps": true,
            "webRoot": "${workspaceRoot}",
            "url": "http://localhost:9877/debug.html",
            "runtimeArgs": []
        },
        {
            "name": "test-node",
            "type": "node",
            "request": "launch",
            "runtimeArgs": [
                "run-script",
                "test-node"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "outFiles": [
                "${workspaceFolder}/**/*.js",
                "${workspaceFolder}/**/*.c",
                "!**/node_modules/**"
            ],
        },
        {
            "name": "test-browser",
            "type": "node",
            "request": "launch",
            "runtimeArgs": [
                "run-script",
                "test-browser"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "outFiles": [
                "${workspaceFolder}/**/*.js",
                "${workspaceFolder}/**/*.c",
                "!**/node_modules/**"
            ],
        },
        {
            "name": "http://127.0.0.1:8080",
            "type": "msedge",
            "request": "launch",
            "url": "http://127.0.0.1:8080",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "smartStep": true,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeArgs": [
                "--disable-web-security"
            ]
        },
        {
            "name": "index-docs",
            "type": "node",
            "program": "${workspaceFolder}/dist-test/index-docs.node.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}