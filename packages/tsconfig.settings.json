{
    "compilerOptions": {
        "composite": true,
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "Node",
        "strict": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "forceConsistentCasingInFileNames": true,
        "lib": [
            "DOM",
            "ES2019"
        ],
        "types": [
            "@types/emscripten",
            "mocha",
            "node"
        ]
    }
}